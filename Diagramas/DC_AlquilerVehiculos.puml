@startuml DC_AlquilerVehiculos
skinparam classAttributeIconSize 0
skinparam linetype ortho
hide empty members

' ─────────────── ENUMS ───────────────

enum EstadoCliente { 
    ACTIVO
    INACTIVO 
}

enum EstadoVehiculo { 
    DISPONIBLE
    ALQUILADO
    MANTENIMIENTO
    BAJA 
}

enum EstadoAlquiler { 
    INGRESADO
    CONFIRMADO
    EN_CURSO
    FINALIZADO
    CANCELADO 
}

enum EstadoPago { 
    REGISTRADO
    CONFIRMADO
    ANULADO 
}

enum TipoVehiculo { 
    AUTO
    CAMIONETA
    UTILITARIO
    MOTO 
}

enum TipoCombustible { 
    NAFTA
    DIESEL
    GNC
    ELECTRICO
    HIBRIDO 
}

enum MedioPago { 
    EFECTIVO
    TRANSFERENCIA
    TARJETA
    BILLETERA_VIRTUAL 
}

enum TipoPago { 
    SENIA
    SALDO 
}

enum TipoEntidad { 
    CLIENTE
    VEHICULO
    ALQUILER
    PAGO 
}

' ─────────────── MODELO ───────────────

class HistorialCambioEstado {
    - id : int
    - fechaCambio : Date
    - estadoAnterior : String
    - estadoNuevo : String
    - tipoEntidad : TipoEntidad
    - referenciaEntidad : String
    - usuarioResponsable : String
    + HistorialCambioEstado(fecha, ant, nuevo, tipo, ref, usr)
}

class Cliente {
    - dniCuit : String
    - nombreRazonSocial : String
    - telefono : String
    - email : String
    - direccion : String
    - estado : EstadoCliente
    - creditoAFavor : double
    + Cliente(dniCuit, nombreRazonSocial, telefono, email, direccion)
    + activar() : void
    + agregarCredito(importe : double) : void
    + getDniCuit() : String
    + getNombreRazonSocial() : String
    + getTelefono() : String
    + getEmail() : String
    + getDireccion() : String
    + getEstado() : EstadoCliente
    + getCreditoAFavor() : double
}

class Vehiculo {
    - patente : String
    - marca : String
    - modelo : String
    - anio : int
    - kilometrajeActual : int
    - estado : EstadoVehiculo
    - valorDiario : double
    - tipoVehiculo : TipoVehiculo
    - tipoCombustible : TipoCombustible
    - kmIncluidosPorDia : int
    - costoKmExcedente : double
    + Vehiculo(patente, marca, modelo, anio, kilometrajeActual, valorDiario, tipoVehiculo, tipoCombustible, kmIncluidosPorDia, costoKmExcedente)
    + cambiarEstado(nuevoEstado : EstadoVehiculo) : void
    + estaDisponible(fInicio : Date, fFin : Date, alquileres : List) : boolean
    + actualizarKilometraje(kmFinal : int) : void
    + getPatente() : String
    + getTipoVehiculo() : TipoVehiculo
    + getMarca() : String
    + getModelo() : String
    + getAnio() : int
    + getKilometrajeActual() : int
    + getEstado() : EstadoVehiculo
    + getValorDiario() : double
    + getTipoCombustible() : TipoCombustible
    + getKmIncluidosPorDia() : int
    + getCostoKmExcedente() : double
}

class Pago {
    - id : int
    - fecha : Date
    - importe : double
    - medioPago : MedioPago
    - estado : EstadoPago
    - usuarioRegistrador : String
    - tipoPago : TipoPago
    + Pago(id, fecha, importe, medioPago, usuario, tipoPago)
    + confirmar() : void
    + anular() : void
    + esSeniaConfirmada() : boolean
    + getImporte() : double
    + getId() : int
    + getFecha() : Date
    + getMedioPago() : MedioPago
    + getEstado() : EstadoPago
    + getUsuarioRegistrador() : String
    + getTipoPago() : TipoPago
}

abstract class Alquiler {
    - id : int
    - fechaInicio : Date
    - fechaDevolucionEstimada : Date
    - fechaDevolucionReal : Date
    - estado : EstadoAlquiler
    - kilometrajeInicial : int
    - kilometrajeFinal : int
    - importeTotal : double
    - importePendiente : double
    + Alquiler(cliente, vehiculo, fInicio, fDevEst, kmIni)
    + cambiarEstado(nuevoEstado : EstadoAlquiler) : void
    + calcularDias() : int
    + calcularImporteBase() : double
    + calcularKmExcedentes() : double
    + calcularSeniaAbonada() : double
    + calcularSaldoPendiente() : double
    + calcularHorasAnticipacion(fCancelacion : Date) : long
    + agregarPago(pago : Pago) : void
    + seSuperpone(fInicio : Date, fFin : Date) : boolean
    + {abstract} calcularImporteTotal() : double
    + getId() : int
    + getFechaInicio() : Date
    + getFechaDevolucionEstimada() : Date
    + getFechaDevolucionReal() : Date
    + getEstado() : EstadoAlquiler
    + getKilometrajeInicial() : int
    + getKilometrajeFinal() : int
    + getImporteTotal() : double
    + getImportePendiente() : double
    + getCliente() : Cliente
    + getVehiculo() : Vehiculo
    + getPagos() : List<Pago>
    + setKilometrajeFinal(km : int) : void
    + setFechaDevolucionReal(fecha : Date) : void
    + setImporteTotal(importe : double) : void
    + setImportePendiente(importe : double) : void
}

class AlquilerComun {
    + AlquilerComun(cliente, vehiculo, fInicio, fDevEst, kmIni)
    + calcularImporteTotal() : double
}

class AlquilerCorporativo {
    - porcentajeDescuento : double
    + AlquilerCorporativo(cliente, vehiculo, fInicio, fDevEst, kmIni, porcentajeDescuento)
    + calcularImporteTotal() : double
    + getPorcentajeDescuento() : double
    + setPorcentajeDescuento(p : double) : void
}

class AlquilerTuristico {
    - porcentajeRecargo : double
    + AlquilerTuristico(cliente, vehiculo, fInicio, fDevEst, kmIni, porcentajeRecargo)
    + calcularImporteTotal() : double
    + getPorcentajeRecargo() : double
    + setPorcentajeRecargo(p : double) : void
}

' ─────────────── CONTROLADORES SINGLETON ───────────────

class ClienteController <<Singleton>> {
    - {static} instancia : ClienteController
    - clientes : List<Cliente>
    - ClienteController()
    + {static} getInstancia() : ClienteController
    + registrarCliente(dniCuit, nombre, telefono, email, direccion, usuario) : Cliente
    + buscarClientePorDniCuit(dniCuit : String) : Cliente
    + alquileresConfirmadosDeCliente(dniCuit : String) : List<Alquiler>
    + getClientes() : List<Cliente>
}

class VehiculoController <<Singleton>> {
    - {static} instancia : VehiculoController
    - vehiculos : List<Vehiculo>
    - VehiculoController()
    + {static} getInstancia() : VehiculoController
    + registrarVehiculo(patente, marca, modelo, anio, km, valorDiario, tipo, combustible, kmD, cKm, usuario) : Vehiculo
    + buscarVehiculoPorPatente(patente : String) : Vehiculo
    + consultarVehiculosDisponibles(fInicio : Date, fFin : Date, tipo : TipoVehiculo) : List<Vehiculo>
    + getVehiculos() : List<Vehiculo>
}

class AlquilerController <<Singleton>> {
    - {static} instancia : AlquilerController
    - alquileres : List<Alquiler>
    - porcentajeDescuentoCorporativo : double
    - porcentajeRecargoTuristico : double
    - AlquilerController()
    + {static} getInstancia() : AlquilerController
    + solicitarAlquiler(dniCuit, patente, fInicio, fFin, clase, usuario) : Alquiler
    + confirmarAlquilerConSenia(idAlquiler, importe, medioPago, usuario) : Pago
    + cancelarAlquiler(idAlquiler, fCancelacion, usuario) : void
    + iniciarAlquiler(idAlquiler, usuario) : void
    + finalizarAlquiler(idAlquiler, kmFinal, fDevReal, usuario) : double
    + buscarPorId(id : int) : Alquiler
    + totalRecaudadoPorPeriodo(desde : Date, hasta : Date) : double
    + obtenerPorcentajeAplicable(alquiler : Alquiler) : double
    + getAlquileres() : List<Alquiler>
}

class PagoController <<Singleton>> {
    - {static} instancia : PagoController
    - pagos : List<Pago>
    - PagoController()
    + {static} getInstancia() : PagoController
    + registrarPago(idAlquiler, importe, medioPago, tipoPago, usuario) : Pago
    + anularPago(idPago, usuario) : void
    + getPagos() : List<Pago>
}

class HistorialController <<Singleton>> {
    - {static} instancia : HistorialController
    - historiales : List<HistorialCambioEstado>
    - HistorialController()
    + {static} getInstancia() : HistorialController
    + registrar(ant, nuevo, tipo : TipoEntidad, ref, usuario) : HistorialCambioEstado
    + getHistoriales() : List<HistorialCambioEstado>
}

' ─────────────── VISTAS SWING ───────────────

class RegistrarClienteView {
    - ctrl : ClienteController
    + inicializarUI() : void
    - registrarCliente() : void
}

class SolicitarAlquilerView {
    - ctrlAlq : AlquilerController
    - ctrlCli : ClienteController
    - ctrlVeh : VehiculoController
    + inicializarUI() : void
    - solicitarAlquiler() : void
}

class ConsultarDisponibilidadView {
    - ctrlVeh : VehiculoController
    + inicializarUI() : void
    - consultar() : void
}

' ─────────────── HERENCIA ───────────────

Alquiler <|-- AlquilerComun
Alquiler <|-- AlquilerCorporativo
Alquiler <|-- AlquilerTuristico

' ─────────────── ASOCIACIONES DEL MODELO ───────────────

Cliente  "1"    o-- "0..*" Alquiler
Vehiculo "1"    o-- "0..*" Alquiler
Alquiler "1"    *-- "0..*" Pago
HistorialCambioEstado "0..*" -- "0..1" Cliente
HistorialCambioEstado "0..*" -- "0..1" Vehiculo
HistorialCambioEstado "0..*" -- "0..1" Alquiler

' ─────────────── CONTROLADORES GESTIONAN COLECCIONES ───────────────

ClienteController   "1" *-- "0..*" Cliente
VehiculoController  "1" *-- "0..*" Vehiculo
AlquilerController  "1" *-- "0..*" Alquiler
PagoController      "1" *-- "0..*" Pago
HistorialController "1" *-- "0..*" HistorialCambioEstado

' ─────────────── DEPENDENCIAS ENTRE CONTROLADORES ───────────────

ClienteController  ..> HistorialController
VehiculoController ..> HistorialController
AlquilerController ..> HistorialController
PagoController     ..> HistorialController
AlquilerController ..> ClienteController
AlquilerController ..> VehiculoController
AlquilerController ..> PagoController

' ─────────────── VISTAS USAN CONTROLADORES ───────────────

RegistrarClienteView        ..> ClienteController
SolicitarAlquilerView       ..> AlquilerController
SolicitarAlquilerView       ..> ClienteController
SolicitarAlquilerView       ..> VehiculoController
ConsultarDisponibilidadView ..> VehiculoController

@enduml
